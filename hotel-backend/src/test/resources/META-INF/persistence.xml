<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">

    <persistence-unit name="hotel-test-pu" transaction-type="RESOURCE_LOCAL">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

        <class>cz.fit.hotel.model.Customer</class>
        <class>cz.fit.hotel.model.Employee</class>
        <class>cz.fit.hotel.model.ExtraService</class>
        <class>cz.fit.hotel.model.Payment</class>
        <class>cz.fit.hotel.model.Reservation</class>
        <class>cz.fit.hotel.model.ReservationChangeLog</class>
        <class>cz.fit.hotel.model.ReservationExtraService</class>
        <class>cz.fit.hotel.model.Room</class>
        <class>cz.fit.hotel.model.RoomService</class>
        <class>cz.fit.hotel.model.RoomType</class>

        <properties>
            <property name="jakarta.persistence.jdbc.driver" value="org.h2.Driver"/>
            <property name="jakarta.persistence.jdbc.url" value="jdbc:h2:mem:hoteltestdb;DB_CLOSE_DELAY=-1"/>
            <property name="jakarta.persistence.jdbc.user" value="sa"/>
            <property name="jakarta.persistence.jdbc.password" value=""/>

            <property name="jakarta.persistence.schema-generation.database.action" value="drop-and-create"/>

            <property name="hibernate.show_sql" value="true"/>
            <property name="hibernate.format_sql" value="true"/>
        </properties>
    </persistence-unit>
</persistence>